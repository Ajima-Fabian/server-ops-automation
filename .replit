modules = ["bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'echo \"=== Web Server Automation Scripts ===\"; echo \"\"; echo \"Available scripts:\"; ls -1 scripts/; echo \"\"; echo \"Usage: bash scripts/deploy_web_server.sh\"; echo \"\"; echo \"Config file: configs/sites.conf\"; cat configs/sites.conf; echo \"\"; echo \"Scripts are ready. Run deploy_web_server.sh to deploy.\"; tail -f /dev/null'"

[workflows.workflow.metadata]
outputType = "console"
